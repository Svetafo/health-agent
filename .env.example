# --- n8n ---
N8N_BASIC_AUTH_USER=you@example.com
N8N_BASIC_AUTH_PASSWORD=
GENERIC_TIMEZONE=UTC
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=

# --- Postgres ---
PG_DB=healthagent
PG_USER=healthagent
PG_PASS=
DATABASE_URL=postgresql://healthagent:your_pass@db:5432/healthagent

# --- App ---
APP_ENV=local
APP_PORT=8000
TELEGRAM_BOT_TOKEN=
HEALTH_USER_ID=            # Telegram user ID — get it via @userinfobot
ALLOWED_USER_IDS=          # Comma-separated whitelist: 195374487,987654321. Empty = open access

# --- LLM ---
LLM_PROVIDER=openai        # openai | anthropic | gemini
GEMINI_API_KEY=            # aistudio.google.com — free tier
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=              # console.groq.com — free, Whisper 2h/day
