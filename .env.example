# --- n8n ---
N8N_BASIC_AUTH_USER=you@example.com
N8N_BASIC_AUTH_PASSWORD=
GENERIC_TIMEZONE=Europe/Moscow
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=

# --- Postgres ---
PG_DB=bmindset
PG_USER=bmind
PG_PASS=
DATABASE_URL=postgresql://bmind:your_pass@db:5432/bmindset

# --- App ---
APP_ENV=local
APP_PORT=8000
TELEGRAM_BOT_TOKEN=
HEALTH_USER_ID=            # Telegram user ID, узнать через @userinfobot
ALLOWED_USER_IDS=          # Whitelist через запятую: 195374487,987654321. Пусто = доступ для всех

# --- LLM ---
LLM_PROVIDER=openai        # openai | anthropic | gemini (free tier недоступен для RU-аккаунтов)
GEMINI_API_KEY=            # aistudio.google.com — бесплатно
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=              # console.groq.com — бесплатно, Whisper 2ч/день
